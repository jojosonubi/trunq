NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Transactional email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key

# Supabase Database Webhook secret (set in Supabase → Database → Webhooks)
# Used to verify POST /api/webhooks/user-created requests are from Supabase
SUPABASE_WEBHOOK_SECRET=your_webhook_secret

# Public app URL — used to build delivery portal links in emails
NEXT_PUBLIC_APP_URL=https://trunq.so
